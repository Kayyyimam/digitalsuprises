        <div id="feedback" class="feedback"></div>
      </div>

      <div id="resultScreen" class="screen">
        <div class="result-wrap">
          <h2 class="title" style="font-size:clamp(1.6rem,4.6vw,2.4rem);margin-bottom:2px">Who Knows The Groom Best? ✨</h2>
          <div id="scoreRing" class="score-ring">
            <div id="scoreValue" class="score-text">0%</div>
          </div>
          <p id="resultMessage" class="subtitle" style="margin:0;max-width:45ch"></p>
          <div class="leaderboard">
            <div class="leaderboard-header">
              <span>Leaderboard</span>
              <span>Top Scores</span>
            </div>
            <ul id="leaderboardList" class="leaderboard-list"></ul>
            <div id="leaderboardEmpty" class="leaderboard-empty">No scores yet. Finish a quiz to create the first record.</div>
          </div>
          <div class="footer-actions">
            <button id="downloadBtn" class="btn btn-secondary" type="button">Download Leaderboard</button>
            <button id="restartBtn" class="btn" type="button">Restart Quiz</button>
            <button id="homeBtn" class="btn btn-secondary" type="button">Back to Welcome</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const QUESTIONS = [
      {
