  </div>

  <main class="app">
    <section class="card" aria-live="polite">
      <div id="homeScreen" class="screen active">
        <div class="home-hero">
          <span class="home-badge">Wedding Night Faceoff</span>
          <h1 class="title">Muhammad & Rahma Groom Challenge 🌙</h1>
          <p class="subtitle">
            Friends, step into the groom arena. Answer fast, score high, and prove who really knows Muhammad best.
          </p>
        </div>
        <div class="home-grid">
          <div class="home-panel">
            <div class="welcome-row">
              <input id="guestName" class="input" type="text" maxlength="24" placeholder="Enter your name or team name">
              <button id="startBtn" class="btn" type="button">Enter Challenge</button>
            </div>
          </div>
          <div class="home-metrics">
            <div class="metric">
              <div class="metric-label">Rounds</div>
