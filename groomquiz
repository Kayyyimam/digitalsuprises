<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Muhammad & Rahma - Groom Challenge Quiz</title>
  <style>
    :root {
      --bg-1: #05070c;
      --bg-2: #0d111a;
      --bg-3: #151d2a;
      --accent: #4ea3ff;
      --accent-soft: #7fc5ff;
      --white: #edf3ff;
      --muted: #a8b3c9;
      --glass: rgba(110, 146, 200, 0.1);
      --glass-border: rgba(142, 174, 224, 0.24);
      --ok: #96e2ad;
      --bad: #f1bfc7;
      --shadow: 0 24px 64px rgba(1, 5, 14, 0.65);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      height: 100%;
      font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
      color: var(--white);
      background: radial-gradient(circle at 20% 18%, rgba(78, 163, 255, 0.14), transparent 40%),
        radial-gradient(circle at 80% 12%, rgba(127, 197, 255, 0.08), transparent 34%),
        linear-gradient(130deg, var(--bg-1), var(--bg-2), var(--bg-3));
      overflow-x: hidden;
    }

    body {
      position: relative;
      min-height: 100vh;
    }

    .geometry {
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(60deg, rgba(103, 151, 230, 0.13) 1px, transparent 1px),
        linear-gradient(-60deg, rgba(103, 151, 230, 0.13) 1px, transparent 1px);
      background-size: 42px 42px;
      opacity: 0.18;
      mask-image: radial-gradient(circle at center, black 20%, transparent 80%);
    }

    .orbs {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
    }

    .orb {
      position: absolute;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      filter: blur(30px);
      opacity: 0.14;
      animation: floatOrb linear infinite;
    }

    .orb.one {
      background: #3f88da;
      top: 8%;
      left: -70px;
      animation-duration: 21s;
    }

    .orb.two {
      background: #74b0ff;
      top: 52%;
      right: -100px;
      animation-duration: 25s;
    }

    .orb.three {
      background: #2868bd;
      bottom: -80px;
      left: 30%;
      animation-duration: 27s;
    }

    #stars {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    .app {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 20px;
    }

    .card {
      width: min(760px, 94vw);
      background: var(--glass);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid var(--glass-border);
      box-shadow: var(--shadow);
      border-radius: 24px;
      padding: clamp(22px, 4vw, 36px);
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -1px;
      background: linear-gradient(120deg, rgba(78, 163, 255, 0.24), transparent 35%, rgba(255, 255, 255, 0.08));
      border-radius: 24px;
      pointer-events: none;
    }

    .screen {
      display: none;
      animation: reveal 550ms ease both;
    }

    .screen.active {
      display: block;
    }

    .home-hero {
      display: grid;
      gap: 18px;
    }

    .home-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      border: 1px solid rgba(127, 197, 255, 0.32);
      border-radius: 999px;
      padding: 6px 12px;
      color: var(--accent-soft);
      background: rgba(78, 163, 255, 0.12);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .home-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: 1.2fr 0.8fr;
      align-items: stretch;
    }

    .home-panel {
      background: linear-gradient(170deg, rgba(10, 21, 39, 0.92), rgba(8, 15, 27, 0.9));
      border: 1px solid rgba(127, 197, 255, 0.2);
      border-radius: 16px;
      padding: 16px;
    }

    .home-metrics {
      display: grid;
      gap: 10px;
    }

    .metric {
      border: 1px solid rgba(127, 197, 255, 0.18);
      background: rgba(78, 163, 255, 0.08);
      border-radius: 12px;
      padding: 10px 12px;
    }

    .metric-label {
      color: var(--muted);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 4px;
    }

    .metric-value {
      color: var(--white);
      font-size: 1.02rem;
      font-weight: 700;
    }

    .title {
      font-family: "Georgia", "Times New Roman", serif;
      font-size: clamp(1.8rem, 5vw, 3rem);
      line-height: 1.15;
      margin: 0 0 12px;
      color: var(--white);
      letter-spacing: 0.02em;
      text-transform: uppercase;
      text-wrap: balance;
    }

    .subtitle {
      color: var(--muted);
      margin: 0 0 24px;
      font-size: clamp(1rem, 2.5vw, 1.1rem);
      line-height: 1.6;
    }

    .welcome-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 0;
    }

    .input {
      flex: 1 1 220px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(9, 16, 29, 0.64);
      color: var(--white);
      outline: none;
      transition: border-color 200ms ease, box-shadow 200ms ease;
      font-size: 1rem;
    }

    .input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(78, 163, 255, 0.25);
    }

    .btn {
      border: none;
      border-radius: 12px;
      padding: 12px 18px;
      color: #08152a;
      background: linear-gradient(180deg, #8dc6ff, #4f9dfa);
      font-weight: 700;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 180ms ease, filter 180ms ease;
      position: relative;
      overflow: hidden;
      font-size: 1rem;
    }

    .btn:hover,
    .btn:focus-visible {
      transform: translateY(-1px);
      box-shadow: 0 0 0 3px rgba(78, 163, 255, 0.24), 0 10px 25px rgba(78, 163, 255, 0.38);
      filter: brightness(1.03);
      outline: none;
    }

    .btn:active {
      transform: translateY(1px);
    }

    .ripple {
      position: absolute;
      border-radius: 50%;
      transform: scale(0);
      animation: ripple 520ms linear;
      background: rgba(255, 255, 255, 0.65);
      pointer-events: none;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      margin-bottom: 14px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .progress-wrap {
      height: 8px;
      width: 100%;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      overflow: hidden;
      margin-bottom: 16px;
    }

    .progress {
      height: 100%;
      width: 0%;
      border-radius: 999px;
      background: linear-gradient(90deg, #3c82d8, #7fc5ff);
      transition: width 350ms ease;
    }

    .question {
      font-size: clamp(1.1rem, 2.8vw, 1.35rem);
      font-weight: 700;
      margin: 8px 0 16px;
      line-height: 1.45;
      text-wrap: balance;
    }

    .options {
      display: grid;
      gap: 10px;
    }

    .option {
      width: 100%;
      text-align: left;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(9, 17, 31, 0.74);
      color: var(--white);
      border-radius: 12px;
      padding: 12px 14px;
      cursor: pointer;
      transition: border-color 160ms ease, transform 150ms ease, background 200ms ease;
      font-size: 0.98rem;
    }

    .option:hover:not(:disabled),
    .option:focus-visible:not(:disabled) {
      border-color: var(--accent);
      transform: translateX(2px);
      outline: none;
    }

    .option:disabled {
      cursor: not-allowed;
      opacity: 0.95;
    }

    .option.correct {
      background: rgba(80, 148, 91, 0.26);
      border-color: var(--ok);
    }

    .option.wrong {
      background: rgba(181, 113, 113, 0.22);
      border-color: var(--bad);
    }

    .feedback {
      min-height: 28px;
      margin-top: 12px;
      color: var(--accent-soft);
      font-size: 0.98rem;
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0;
      transform: translateY(3px);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .feedback.show {
      opacity: 1;
      transform: translateY(0);
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(78, 163, 255, 0.14);
      color: var(--accent-soft);
      font-size: 0.85rem;
      margin-bottom: 8px;
    }

    .result-wrap {
      display: grid;
      place-items: center;
      text-align: center;
      gap: 14px;
    }

    .score-ring {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      position: relative;
      background: conic-gradient(var(--accent) 0deg, rgba(255, 255, 255, 0.15) 0deg);
      box-shadow: inset 0 0 30px rgba(1, 5, 22, 0.45), 0 15px 35px rgba(0, 0, 0, 0.25);
    }

    .score-ring::after {
      content: "";
      position: absolute;
      inset: 14px;
      border-radius: 50%;
      background: rgba(5, 24, 32, 0.95);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .score-text {
      position: relative;
      z-index: 1;
      font-size: 2rem;
      font-weight: 800;
      color: var(--accent-soft);
    }

    .footer-actions {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 8px;
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.1);
      color: var(--white);
      border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .glow-burst {
      position: absolute;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--accent-soft);
      box-shadow: 0 0 18px 8px rgba(127, 197, 255, 0.48);
      animation: burst 900ms ease-out forwards;
      pointer-events: none;
      z-index: 4;
    }

    .leaderboard {
      width: 100%;
      margin-top: 8px;
      border: 1px solid rgba(127, 197, 255, 0.2);
      border-radius: 14px;
      background: rgba(10, 18, 31, 0.72);
      overflow: hidden;
    }

    .leaderboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-bottom: 1px solid rgba(127, 197, 255, 0.2);
      color: var(--accent-soft);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .leaderboard-list {
      margin: 0;
      padding: 0;
      list-style: none;
      max-height: 220px;
      overflow: auto;
    }

    .leaderboard-row {
      display: grid;
      grid-template-columns: 40px 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 10px 14px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      color: var(--white);
      font-size: 0.94rem;
    }

    .leaderboard-row:last-child {
      border-bottom: none;
    }

    .leaderboard-rank {
      color: var(--accent-soft);
      font-weight: 800;
    }

    .leaderboard-score {
      font-weight: 700;
      color: var(--accent-soft);
    }

    .leaderboard-empty {
      padding: 14px;
      color: var(--muted);
      text-align: left;
      font-size: 0.92rem;
    }

    @keyframes reveal {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.985);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes ripple {
      to {
        transform: scale(4);
        opacity: 0;
      }
    }

    @keyframes floatOrb {
      0%,
      100% {
        transform: translateY(0px) translateX(0px);
      }
      50% {
        transform: translateY(-24px) translateX(16px);
      }
    }

    @keyframes burst {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 1;
      }
      100% {
        transform: translate(var(--tx), var(--ty)) scale(0.2);
        opacity: 0;
      }
    }

    @media (max-width: 600px) {
      .home-grid {
        grid-template-columns: 1fr;
      }

      .card {
        border-radius: 18px;
      }

      .score-ring {
        width: 140px;
        height: 140px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 1ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 1ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <canvas id="stars" aria-hidden="true"></canvas>
