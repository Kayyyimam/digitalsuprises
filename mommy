<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mama Appreciation</title>

<style>
  body {
    margin: 0;
    background: #ffffff;
    font-family: Arial, sans-serif;
    overflow: hidden;
  }

  /* soft emotional background */
  body::before {
    content: "";
    position: absolute;
    width: 120%;
    height: 120%;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, rgba(255,0,0,0.05), transparent 60%);
    animation: breathe 6s ease-in-out infinite;
  }

  @keyframes breathe {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.05); opacity: 1; }
  }

  /* SCREEN */
  .screen, .final {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  /* CENTER WRAPPER FIX (prevents drifting issue) */
  .center-wrapper {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ✨ IMPROVED MAMA DESIGN */
  .mama {
    font-size: 4rem;
    font-weight: 800;
    color: #cc0000;
    letter-spacing: 6px;
    position: relative;
    text-transform: uppercase;
    text-shadow: 0 0 18px rgba(204,0,0,0.25);
  }

  .mama::after {
    content: "";
    position: absolute;
    width: 60%;
    height: 3px;
    background: rgba(204,0,0,0.4);
    bottom: -10px;
    left: 20%;
    border-radius: 5px;
  }

  /* CORNER MESSAGES */
  .msg {
    position: absolute;
    font-size: 1.05rem;
    max-width: 220px;
    opacity: 0;
    transform: translateY(10px);
    transition: all 1.2s ease;
    color: #b30000;
    line-height: 1.4;
  }

  .show {
    opacity: 1;
    transform: translateY(0);
  }

  .m1 { top: 80px; left: 80px; }
  .m2 { top: 80px; right: 80px; }
  .m3 { bottom: 80px; left: 80px; }
  .m4 { bottom: 80px; right: 80px; }

  /* HEART */
  .heart {
    display: inline-block;
    margin-left: 6px;
    animation: float 2s ease-in-out infinite;
  }

  @keyframes float {
    0% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-7px) scale(1.2); opacity: 1; }
    100% { transform: translateY(0) scale(1); opacity: 0.6; }
  }

  /* FINAL SCREEN FIXED CENTER */
  .final {
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    text-align: center;
  }

  .final-text {
    font-size: 3rem;
    font-weight: 800;
    color: #cc0000;
    opacity: 0;
    transform: scale(0.9);
    transition: all 1.5s ease;
  }

  .final-sub {
    margin-top: 12px;
    font-size: 1.1rem;
    color: #a30000;
    opacity: 0;
    transition: all 1.5s ease;
  }

  .show-final {
    opacity: 1;
    transform: scale(1);
  }

</style>
</head>

<body>

<!-- SCREEN 1 -->
<div class="screen" id="screen1">

  <div class="center-wrapper">
    <div class="mama">MAMA</div>
  </div>

  <div class="msg m1" id="m1">You are my strength <span class="heart">❤️</span></div>
  <div class="msg m2" id="m2">You never gave up on me <span class="heart">❤️</span></div>
  <div class="msg m3" id="m3">Your love shaped my life <span class="heart">❤️</span></div>
  <div class="msg m4" id="m4">I am forever grateful <span class="heart">❤️</span></div>

</div>

<!-- FINAL SCREEN -->
<div class="final" id="screen2">
  <div class="final-text" id="finalText">I love you soo much ❤️</div>
  <div class="final-sub" id="finalSub">Forever and always.</div>
</div>

<script>
const msgs = ["m1","m2","m3","m4"];
let i = 0;

function showMessages() {
  if (i >= msgs.length) {
    setTimeout(showFinal, 1200);
    return;
  }

  document.getElementById(msgs[i]).classList.add("show");
  i++;

  setTimeout(showMessages, 1400);
}

function showFinal() {
  document.getElementById("screen1").style.opacity = 0;

  setTimeout(() => {
    document.getElementById("screen1").style.display = "none";
    document.getElementById("screen2").style.display = "flex";

    setTimeout(() => {
      document.getElementById("finalText").classList.add("show-final");
    }, 400);

    setTimeout(() => {
      document.getElementById("finalSub").classList.add("show-final");
    }, 1300);

  }, 1000);
}

showMessages();
</script>

</body>
</html>
