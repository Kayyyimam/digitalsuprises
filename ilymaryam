<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>I Love You Umma</title>

<style>
  body {
    margin: 0;
    background: black;
    overflow: hidden;
    font-family: serif;
  }

  .center-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
    color: #d8b4ff;
    text-shadow: 0 0 10px #a855f7, 0 0 25px #9333ea;
  }

  .center-text h1 {
    margin: 0;
    font-size: 2.5rem;
  }

  canvas {
    position: absolute;
    top: 0;
    left: 0;
  }
</style>
</head>

<body>

<div class="center-text">
  <h1>I love you<br>Maryam</h1>
</div>

<canvas id="c"></canvas>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let t = 0;
let points = [];

// Heart equation
function heart(t) {
  return {
    x: 16 * Math.pow(Math.sin(t), 3),
    y: -(13 * Math.cos(t) - 5 * Math.cos(2*t) - 2 * Math.cos(3*t) - Math.cos(4*t))
  };
}

function draw() {
ctx.fillStyle = "#000";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  let centerX = canvas.width / 2;
  let centerY = canvas.height / 2;

  // Generate next point
  if (t <= Math.PI * 2) {
    let p = heart(t);

    let x = centerX + p.x * 15;
    let y = centerY + p.y * 15;

    points.push({x, y});
    t += 0.02;
  }

  // Draw glowing trail
  ctx.beginPath();
  for (let i = 0; i < points.length; i++) {
    let p = points[i];
    ctx.lineTo(p.x, p.y);
  }

  ctx.strokeStyle = "#a855f7";
  ctx.lineWidth = 3;
  ctx.shadowBlur = 20;
  ctx.shadowColor = "#a855f7";
  ctx.stroke();

  // Draw moving glowing dot
  if (points.length > 0) {
    let last = points[points.length - 1];

    ctx.beginPath();
    ctx.arc(last.x, last.y, 5, 0, Math.PI * 2);
    ctx.fillStyle = "#d8b4ff";
    ctx.shadowBlur = 25;
    ctx.shadowColor = "#c084fc";
    ctx.fill();
  }

  requestAnimationFrame(draw);
}

draw();
</script>

</body>
</html>
