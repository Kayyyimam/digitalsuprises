<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Things I Don't Say Enough</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&amp;display=swap" rel="stylesheet">
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse-glow {
      0%, 100% { text-shadow: 0 0 20px rgba(255,180,120,0.3); }
      50% { text-shadow: 0 0 40px rgba(255,180,120,0.6); }
    }
    @keyframes gentle-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    .msg-reveal {
      animation: fadeUp 1s ease forwards;
    }
    .final-glow {
      animation: pulse-glow 3s ease-in-out infinite;
    }
    .float-prompt {
      animation: gentle-float 2.5s ease-in-out infinite;
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js" type="text/javascript"></script>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full bg-black">
  <div id="app" class="h-full w-full flex flex-col items-center justify-center overflow-auto relative" style="font-family: 'Cormorant Garamond', serif;">
   <div id="title-area" class="absolute top-12 left-0 right-0 text-center px-6">
    <h1 id="main-title" class="text-lg tracking-[0.3em] uppercase text-neutral-500 font-semibold"></h1>
   </div>
   <div id="messages-container" class="flex flex-col items-center gap-8 px-6 max-w-lg w-full py-24">
   </div>
   <div id="prompt" class="absolute bottom-10 left-0 right-0 text-center float-prompt">
    <p class="text-neutral-600 text-sm tracking-widest uppercase">tap anywhere</p>
   </div>
  </div>
  <script>
    const messages = [
      "I'm proud of you.",
      "You make the world softer\njust by being in it.",
      "I notice the little things you do\nfor everyone else.",
      "You deserve the love\nyou keep giving away.",
      "I'm sorry for the times\nI didn't show up.",
      "Your presence is a gift\nI never want to take for granted.",
      "Thank you for staying.",
      "You are enough.\nYou have always been enough."
    ];

    const finalMessage = "I love you.\nMore than I'll ever\nknow how to say.";

    let currentIndex = 0;
    let finished = false;
    const container = document.getElementById('messages-container');
    const prompt = document.getElementById('prompt');

    function revealNext() {
      if (finished) return;

      if (currentIndex < messages.length) {
        const el = document.createElement('div');
        el.className = 'msg-reveal text-center';
        el.style.opacity = '0';
        const text = messages[currentIndex];
        el.innerHTML = text.split('\n').map(line =>
          `<p class="text-2xl md:text-3xl text-neutral-300 leading-relaxed" style="font-family: 'Cormorant Garamond', serif; font-style: italic;">${line}</p>`
        ).join('');
        container.appendChild(el);
        currentIndex++;

        if (currentIndex >= messages.length) {
          prompt.querySelector('p').textContent = 'one more';
        }
      } else {
        finished = true;
        prompt.style.display = 'none';

        const el = document.createElement('div');
        el.className = 'msg-reveal text-center mt-8';
        el.style.opacity = '0';
        el.innerHTML = finalMessage.split('\n').map(line =>
          `<p class="text-3xl md:text-4xl font-semibold final-glow" style="color: #f0b080; font-family: 'Cormorant Garamond', serif;">${line}</p>`
        ).join('');
        container.appendChild(el);
      }

      container.lastElementChild.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    document.getElementById('app').addEventListener('click', revealNext);

    // Element SDK
    const defaultConfig = {
      main_title: "Things I Don't Say Enough",
      background_color: "#000000",
      text_color: "#d4d4d4",
      accent_color: "#f0b080",
      font_family: "Cormorant Garamond",
      font_size: 16
    };

    function applyConfig(config) {
      document.getElementById('main-title').textContent = config.main_title || defaultConfig.main_title;
      const bg = config.background_color || defaultConfig.background_color;
      document.getElementById('app').style.backgroundColor = bg;
      const textColor = config.text_color || defaultConfig.text_color;
      document.querySelectorAll('.msg-reveal p:not(.final-glow)').forEach(p => p.style.color = textColor);
      const accent = config.accent_color || defaultConfig.accent_color;
      document.querySelectorAll('.final-glow').forEach(p => p.style.color = accent);
      const font = config.font_family || defaultConfig.font_family;
      document.getElementById('app').style.fontFamily = `${font}, serif`;
      const size = config.font_size || defaultConfig.font_size;
      document.getElementById('main-title').style.fontSize = `${size}px`;
      document.querySelectorAll('.msg-reveal p:not(.final-glow)').forEach(p => p.style.fontSize = `${size * 1.7}px`);
      document.querySelectorAll('.final-glow').forEach(p => p.style.fontSize = `${size * 2}px`);
    }

    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (config) => applyConfig(config),
      mapToCapabilities: (config) => ({
        recolorables: [
          { get: () => config.background_color || defaultConfig.background_color, set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
          { get: () => config.text_color || defaultConfig.text_color, set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
          { get: () => config.accent_color || defaultConfig.accent_color, set: (v) => { config.accent_color = v; window.elementSdk.setConfig({ accent_color: v }); } }
        ],
        borderables: [],
        fontEditable: { get: () => config.font_family || defaultConfig.font_family, set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); } },
        fontSizeable: { get: () => config.font_size || defaultConfig.font_size, set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); } }
      }),
      mapToEditPanelValues: (config) => new Map([
        ["main_title", config.main_title || defaultConfig.main_title]
      ])
    });

    applyConfig(defaultConfig);
  </script>
